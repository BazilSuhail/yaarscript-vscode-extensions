{
  "name": "yaarscript-snippets",
  "displayName": "YaarScript Snippets Pack",
  "description": "Premium Urdu programming snippets for YaarScript. The ultimate collection of high-speed templates for .yaar files including mandatory entry points, loops, and complex algorithmic demos.",
  "version": "1.0.1",
  "publisher": "9b44e0ea-284e-6202-b075-e936e0da1bff",
  "author": "Bazil Suhail",
  "icon": "icons/yaar-script.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/BazilSuhail/yaarscript-vscode-extensions.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets",
    "Education"
  ],
  "keywords": [
    "yaarscript",
    "yaarscript snippets",
    "urdu",
    "programming language",
    "snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "yaarscript",
        "aliases": [
          "YaarScript",
          "yaar"
        ],
        "extensions": [
          ".yaar"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "yaarscript",
        "path": "./snippets/snippets.json"
      }
    ]
  }
}
