{
  "name": "yaarscript",
  "displayName": "YaarScript Support",
  "description": "Syntax highlighting, code runner, and language support for YaarScript (.yaar files), the ultimate Urdu programming language.",
  "version": "1.0.0",
  "publisher": "9b44e0ea-284e-6202-b075-e936e0da1bff",
  "author": "Bazil Suhail",
  "icon": "icons/yaar-script.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/BazilSuhail/yaarscript-vscode-extensions.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Themes",
    "Education"
  ],
  "keywords": [
    "yaarscript",
    "urdu",
    "programming language",
    "syntax highlighting",
    "code runner",
    "compiler"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "yaarscript",
        "aliases": [
          "YaarScript",
          "yaar"
        ],
        "extensions": [
          ".yaar"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/yaar-script-light.png",
          "dark": "./icons/yaar-script.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "yaarscript",
        "scopeName": "source.yaar",
        "path": "./syntaxes/yaarscript.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "YaarScript Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/yaarscript-dark.json"
      }
    ],
    "commands": [
      {
        "command": "yaarscript.run",
        "title": "Run YaarScript",
        "description": "Execute the current YaarScript file",
        "category": "YaarScript",
        "icon": "$(play)"
      }
    ],
    "keybindings": [
      {
        "command": "yaarscript.run",
        "key": "ctrl+shift+r",
        "when": "resourceLangId == yaarscript"
      },
      {
        "command": "yaarscript.run",
        "key": "ctrl+alt+r",
        "when": "resourceLangId == yaarscript"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "yaarscript.run",
          "group": "1_modification",
          "when": "resourceLangId == yaarscript"
        }
      ],
      "editor/title": [
        {
          "command": "yaarscript.run",
          "group": "navigation",
          "when": "resourceLangId == yaarscript"
        }
      ]
    }
  }
}
