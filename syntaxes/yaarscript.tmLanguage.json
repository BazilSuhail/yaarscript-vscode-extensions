{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YaarScript",
  "scopeName": "source.yaar",
  "fileTypes": ["yaar"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.yaar",
          "match": "//.*$"
        },
        {
          "name": "comment.block.yaar",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.yaar",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.yaar",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.yaar",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.yaar",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.yaar",
          "match": "\\b(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.yaar",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.yaar",
          "match": "\\b(agar|warna|agar_ho|bas_kar|jabtak|karo|dohrao|intekhab)\\b"
        },
        {
          "name": "keyword.declaration.yaar",
          "match": "\\b(number|faisla|khaali|qism|pakka|yaar)\\b"
        },
        {
          "name": "keyword.constant.yaar",
          "match": "\\b(sahi|galat)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.yaar",
          "match": "\\b(bolo|suno|waqt|ittifaq)\\s*(?=\\()"
        },
        {
          "name": "constant.language.yaar",
          "match": "\\b(RED|GREEN|BLUE)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.yaar",
          "match": "(\\*\\*|[+\\-*/%]|==|!=|<=|>=|<|>|&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.yaar",
          "match": "="
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.yaar",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.yaar",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
