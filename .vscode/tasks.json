{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "npm: Build ESBuild",
      "type": "shell",
      "command": "npm",
      "args": ["run", "esbuild"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Extension: Package (vsce)",
      "type": "shell",
      "command": "vsce",
      "args": ["package"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
