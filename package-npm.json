{
  "name": "yaarscript-extension",
  "version": "1.0.0",
  "description": "VS Code extension for YaarScript language with syntax highlighting and file icons",
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./extension.js --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "pretest": "npm run esbuild && npm run lint",
    "lint": "eslint src",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0"
  },
  "publisher": "BazilSuhail",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/yaarscript-vscode"
  }
}
